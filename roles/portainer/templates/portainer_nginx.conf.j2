upstream {{ PORTAINER_SERVICE_NAME }}_backend {
    server {{ PORTAINER_DOCKER_SERVICE_NAME }}:9000;
}

server {
    server_name {{ PORTAINER_DOMAIN }};
    listen 80;
    return 301 https://$host$request_uri;
    
    autoindex off;
    server_tokens off;

    access_log /var/log/nginx/{{ PORTAINER_SERVICE_NAME }}-access.log;
    error_log /var/log/nginx/{{ PORTAINER_SERVICE_NAME }}-error.log;
}

server {
    listen 443 ssl;
    server_name {{ PORTAINER_DOMAIN }};
    root /var/www/html;

    autoindex off;
    server_tokens off;

	set $backend "http://{{ PORTAINER_SERVICE_NAME }}_backend";

    location / {
        proxy_set_header  X-Real-IP         $remote_addr;
        proxy_set_header  X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header  Host              $http_host;
        proxy_set_header  X-NginX-Proxy     true;
        proxy_set_header  Connection        "";
        proxy_pass_header X-Transmission-Session-Id;
        add_header        Front-End-Https   on;

        proxy_pass $backend;
    }

    include /etc/nginx/snippets/ssl-params.conf;
    include /etc/nginx/snippets/headers.conf;

    access_log /var/log/nginx/{{ PORTAINER_SERVICE_NAME }}-access.log;
    error_log /var/log/nginx/{{ PORTAINER_SERVICE_NAME }}-error.log;
}
