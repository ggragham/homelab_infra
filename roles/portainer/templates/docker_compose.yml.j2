services:
  {{ PORTAINER_DOCKER_SERVICE_NAME }}:
    container_name: {{ PORTAINER_DOCKER_CONTAINER_NAME }}
    image: portainer/portainer-ce:{{ PORTAINER_DOCKER_VERSION }}
    restart: always
    ports:
      - {{ PORTAINER_DOCKER_HTTP_PORT }}:9443
{% if PORTAINER_DOCKER_EDGE_AGENTS_PORT is defined and PORTAINER_DOCKER_EDGE_AGENTS_PORT is not sameas(false) %}
      - {{ PORTAINER_DOCKER_EDGE_AGENTS_PORT }}:8000
{% endif %}
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - portainer_data:/data

networks:
  default:
    name: portainer_network

volumes:
  portainer_data:
    name: portainer_data
